# 로컬 개발 시 이 파일을 .env.local 로 복사해 실제 값을 채우세요.
# (.env.local 은 git에 커밋되지 않습니다)

# Firebase 웹 API 키 (Firebase 콘솔 > 프로젝트 설정 > 내 앱 > SDK 설정에서 확인)
# 클라이언트에 노출되는 공개 값이라 비밀 키는 아닙니다.
VITE_API_KEY=

# Kakao 로그인 (로그인 기능을 쓸 때만 필요)
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/auth
VITE_KAKAO_SECRET_KEY=
